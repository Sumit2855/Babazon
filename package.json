{
  "name": "shopnest",
  "version": "1.0.0",
  "author": "Shivansh Vasu",
  "description": "Full-Stack MERN E-Commerce App",
  "scripts": {
    "install-all": "npm install && npm --prefix backend install && npm --prefix frontend install",
    "build": "npm run install-all && npm --prefix frontend run build",
    "render-build": "npm run build",
    "start": "npm --prefix backend start",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "npm --prefix backend run dev",
    "start:frontend": "npm --prefix frontend run dev",
    "seed": "npm --prefix backend run seed"
  },
  "dependencies": {
    "concurrently": "^8.2.1"
  }
}